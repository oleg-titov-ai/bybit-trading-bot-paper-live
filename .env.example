# Demo configuration only. Do not put real API keys here.

# Bybit API
BYBIT_API_KEY=DEMO_BYBIT_API_KEY
BYBIT_API_SECRET=DEMO_BYBIT_API_SECRET
BYBIT_TESTNET=true

# Bot mode
TRADING_MODE=paper
LOG_LEVEL=INFO

# Risk controls
